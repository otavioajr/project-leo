{
  "entities": {
    "Adventure": {
      "title": "Adventure",
      "description": "Represents an adventure activity offered by Chaves Adventure.",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "string" },
        "location": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["Fácil", "Moderado", "Desafiador"] },
        "imageUrl": { "type": "string", "format": "uri" },
        "imageDescription": { "type": "string" },
        "registrationsEnabled": { "type": "boolean" },
        "customFields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "email", "tel", "number"] },
              "required": { "type": "boolean" }
            },
            "required": ["name", "label", "type", "required"]
          }
        }
      },
      "required": ["slug", "title", "description", "longDescription", "price", "duration", "location", "difficulty", "imageUrl", "imageDescription", "registrationsEnabled"]
    },
    "Registration": {
      "title": "Registration",
      "description": "Represents a user's registration for an adventure.",
      "type": "object",
      "properties": {
        "adventureId": { "type": "string" },
        "adventureTitle": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "groupSize": { "type": "number" },
        "participants": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": { "type": "string" } }
        }
      },
      "required": ["adventureId", "adventureTitle", "name", "email", "phone", "registrationDate", "groupSize"]
    },
    "HomePageContent": {
      "title": "Home Page Content",
      "description": "Singleton document for the home page content.",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroDescription": { "type": "string" },
        "heroImageUrl": { "type": "string", "format": "uri" },
        "heroImageDescription": { "type": "string" },
        "adventuresTitle": { "type": "string" },
        "adventuresDescription": { "type": "string" }
      },
      "required": ["heroTitle", "heroDescription", "heroImageUrl", "heroImageDescription", "adventuresTitle", "adventuresDescription"]
    },
    "ContentPage": {
      "title": "Content Page",
      "description": "Represents a static content page like 'About' or 'Contact'.",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" }
      },
      "required": ["slug", "title", "content"]
    },
    "AdminRole": {
      "title": "Admin Role",
      "description": "Document presence indicates admin role.",
      "type": "object",
      "properties": {
        "isAdmin": { "type": "boolean" }
      },
      "required": ["isAdmin"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/adventures/{adventureId}": {
      "schema": { "$ref": "#/entities/Adventure" },
      "description": "Stores adventure details."
    },
    "/registrations/{registrationId}": {
      "schema": { "$ref": "#/entities/Registration" },
      "description": "Stores user registrations for adventures."
    },
    "/content/homepage": {
      "schema": { "$ref": "#/entities/HomePageContent" },
      "description": "Stores the content for the main home page."
    },
    "/pages/{pageSlug}": {
      "schema": { "$ref": "#/entities/ContentPage" },
      "description": "Stores content for static pages."
    },
    "/roles_admin/{userId}": {
      "schema": { "$ref": "#/entities/AdminRole" },
      "description": "Manages administrator roles. Document existence implies admin rights."
    }
  }
}
