rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    match /adventures/{adventureId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /content/{docId} {
       allow read: if true;
       allow write: if isAdmin();
    }

    match /pages/{pageSlug} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /roles_admin/{userId} {
      // A user can check their own admin status.
      allow read: if request.auth.uid == userId;
      // Writes are disallowed from the client to prevent privilege escalation.
      // Admins should be managed from the Firebase Console.
      allow write: if false;
    }
  }
}
