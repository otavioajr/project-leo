rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Funcao auxiliar para verificar se o usuario e um administrador
    function isAdmin() {
      return request.auth != null && 
        firestore.exists(/databases/(default)/documents/roles_admin/$(request.auth.uid));
    }

    // Imagens de aventuras - todos podem ver, apenas admins podem fazer upload
    match /adventures/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Imagens da pagina principal - todos podem ver, apenas admins podem fazer upload
    match /homepage/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Imagens genericas - todos podem ver, apenas admins podem fazer upload
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
